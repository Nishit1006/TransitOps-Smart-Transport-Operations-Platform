generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                UserRole
  isActive            Boolean   @default(true)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tripsCreated        Trip[]    @relation("TripCreatedBy")

  @@index([role])
}

model Vehicle {
  id                 String           @id @default(uuid())
  registrationNumber String           @unique
  name               String
  type               VehicleType
  maxLoadCapacityKg  Decimal          @db.Decimal(10, 2)
  odometerKm         Decimal          @default(0) @db.Decimal(10, 2)
  acquisitionCost    Decimal          @db.Decimal(12, 2)
  status             VehicleStatus    @default(AVAILABLE)
  region             String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  expenses           Expense[]
  fuelLogs           FuelLog[]
  maintenanceLogs    MaintenanceLog[]
  trips              Trip[]

  @@index([status])
  @@index([region])
  @@index([type])
}

model Driver {
  id                  String          @id @default(uuid())
  name                String
  licenseNumber       String          @unique
  licenseCategory     LicenseCategory
  licenseExpiryDate   DateTime
  contactNumber       String
  safetyScore         Decimal         @default(100) @db.Decimal(5, 2)
  status              DriverStatus    @default(AVAILABLE)
  tripsCompletedCount Int             @default(0)
  tripsAssignedCount  Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  trips               Trip[]

  @@index([status])
  @@index([licenseExpiryDate])
}

model Trip {
  id                 String     @id @default(uuid())
  source             String
  destination        String
  vehicleId          String
  driverId           String
  cargoWeightKg      Decimal    @db.Decimal(10, 2)
  plannedDistanceKm  Decimal    @db.Decimal(10, 2)
  actualDistanceKm   Decimal?   @db.Decimal(10, 2)
  startOdometerKm    Decimal?   @db.Decimal(10, 2)
  endOdometerKm      Decimal?   @db.Decimal(10, 2)
  fuelConsumedLiters Decimal?   @db.Decimal(10, 2)
  revenue            Decimal?   @db.Decimal(12, 2)
  etaMinutes         Int?
  status             TripStatus @default(DRAFT)
  dispatchedAt       DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdById        String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  expenses           Expense[]
  fuelLogs           FuelLog[]
  createdBy          User       @relation("TripCreatedBy", fields: [createdById], references: [id])
  driver             Driver     @relation(fields: [driverId], references: [id])
  vehicle            Vehicle    @relation(fields: [vehicleId], references: [id])

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id          String            @id @default(uuid())
  vehicleId   String
  serviceType String
  cost        Decimal           @db.Decimal(12, 2)
  status      MaintenanceStatus @default(IN_SHOP)
  serviceDate DateTime          @default(now())
  closedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([status])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  liters    Decimal  @db.Decimal(10, 2)
  cost      Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  trip      Trip?    @relation(fields: [tripId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([date])
}

model Expense {
  id          String      @id @default(uuid())
  vehicleId   String
  tripId      String?
  type        ExpenseType
  amount      Decimal     @db.Decimal(12, 2)
  description String?
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())
  trip        Trip?       @relation(fields: [tripId], references: [id])
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([tripId])
  @@index([type])
  @@index([date])
}

model OrgSettings {
  id           String   @id @default("default")
  depotName    String   @default("Main Depot")
  currency     String   @default("INR")
  distanceUnit String   @default("KM")
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
  ADMIN
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum VehicleType {
  TRUCK
  VAN
  MINI
  TRAILER
  OTHER
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum LicenseCategory {
  LMV
  HMV
  MOTORCYCLE
  COMMERCIAL
  OTHER
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  IN_SHOP
  COMPLETED
}

enum ExpenseType {
  TOLL
  FUEL
  MAINTENANCE
  FINE
  OTHER
}
