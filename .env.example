# ── PostgreSQL ──
POSTGRES_USER=transitops
POSTGRES_PASSWORD=transitops_secret
POSTGRES_DB=transitops

# ── Backend ──
PORT=5000
DATABASE_URL=postgresql://transitops:transitops_secret@db:5432/transitops
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── SMTP ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=TransitOps

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:5001
# Must exactly match the backend's JWT_SECRET above — proxy.ts verifies the
# auth cookie's signature locally to check role before rendering a
# role-restricted page. Never prefix this with NEXT_PUBLIC_.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
